build/
dist/
*.egg-info/
.eggs/
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.tox/
.nox/
coverage.xml

# Type checker caches
.mypy_cache/
.pyre/
.pytype/

# Linter caches
.ruff_cache/

# Jupyter Notebook
.ipynb_checkpoints/

# Logs
logs/
*.log

# Runtime files
*.pid
*.pid.lock

# SQLite databases
*.db
*.sqlite3

# Flask
instance/
.flaskenv

# FastAPI/Uvicorn/Gunicorn
gunicorn.pid

# Temporary files
tmp/
temp/
*.tmp
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

